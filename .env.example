# Library AI Chatbot — Environment Variables
# Copy this file to .env and fill in the values.

# Base URL of your Koha ILS REST API
KOHA_API_URL=http://your-koha-server:8080

# Groq Cloud API key (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Groq Cloud API base URL
GROQ_API_URL=https://api.groq.com

# Path to the library information JSON file
LIBRARY_INFO_PATH=data/library_info.json
